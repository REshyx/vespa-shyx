<ServerManagerConfiguration>
  <ProxyGroup name="representations">
    <RepresentationProxy name="AnimatedStreamlineRepresentation"
                         class="vtkAnimatedStreamlineRepresentation"
                         processes="client|dataserver|renderserver"
                         base_proxygroup="representations"
                         base_proxyname="SurfaceRepresentation">
      <Documentation>
        GPU animated streamline-like representation with custom shader uniforms updated each frame.
      </Documentation>

      <IntVectorProperty name="Animate"
                         command="SetAnimate"
                         default_values="1"
                         number_of_elements="1">
        <BooleanDomain name="bool" />
      </IntVectorProperty>

      <DoubleVectorProperty name="IntegrationScale"
                            command="SetIntegrationScale"
                            default_values="50"
                            number_of_elements="1">
        <DoubleRangeDomain name="range" min="-10" max="100" />
      </DoubleVectorProperty>

      <DoubleVectorProperty name="TimeScale"
                            command="SetTimeScale"
                            default_values="0.4"
                            number_of_elements="1">
        <DoubleRangeDomain name="range" min="-1" max="3" />
      </DoubleVectorProperty>

      <DoubleVectorProperty name="OpacityScale"
                            command="SetOpacityScale"
                            default_values="0.8"
                            number_of_elements="1">
        <DoubleRangeDomain name="range" min="0" max="1" />
      </DoubleVectorProperty>

      <DoubleVectorProperty name="Trunc"
                            command="SetTrunc"
                            default_values="2"
                            number_of_elements="1">
        <DoubleRangeDomain name="range" min="0.01" max="2" />
      </DoubleVectorProperty>

      <DoubleVectorProperty name="Pow"
                            command="SetPow"
                            default_values="1"
                            number_of_elements="1">
        <DoubleRangeDomain name="range" min="0.1" max="5" />
      </DoubleVectorProperty>

      <StringVectorProperty name="AnimationCoordinateArray"
                            command="SetAnimationCoordinateArray"
                            default_values="IntegrationTime"
                            label="Animation coordinate (tcoord.x)"
                            number_of_elements="1">
        <Documentation>
          Point data array driving mesh tcoord.x for the GPU alpha pulse (batched OpenGL path):
          scalars use the value as-is; vectors use sqrt(x*x+y*y+z*z) per point (two components use
          sqrt(x*x+y*y)). Default: IntegrationTime.
        </Documentation>
        <RepresentedArrayListDomain name="array_list"
                                    input_domain_name="input_array_any">
          <RequiredProperties>
            <Property function="Input" name="Input" />
          </RequiredProperties>
        </RepresentedArrayListDomain>
      </StringVectorProperty>
    </RepresentationProxy>

    <Extension name="GeometryRepresentation">
      <RepresentationType subproxy="AnimatedStreamlineRepresentation"
                          text="Animated Streamline" />
      <SubProxy>
        <Proxy name="AnimatedStreamlineRepresentation"
               proxygroup="representations"
               proxyname="AnimatedStreamlineRepresentation" />
        <ShareProperties subproxy="SurfaceRepresentation">
          <Exception name="Input" />
          <Exception name="Visibility" />
          <Exception name="Representation" />
        </ShareProperties>
        <ExposedProperties>
          <PropertyGroup label="Animated Streamline">
            <Property name="Animate" exposed_name="AS_Animate" />
            <Property name="IntegrationScale" exposed_name="AS_IntegrationScale" />
            <Property name="TimeScale" exposed_name="AS_TimeScale" />
            <Property name="OpacityScale" exposed_name="AS_OpacityScale" />
            <Property name="Trunc" exposed_name="AS_Trunc" />
            <Property name="Pow" exposed_name="AS_Pow" />
            <Property name="AnimationCoordinateArray" exposed_name="AS_AnimationCoordinateArray" />
            <Hints>
              <PropertyWidgetDecorator type="GenericDecorator"
                                       mode="visibility"
                                       property="Representation"
                                       value="Animated Streamline" />
            </Hints>
          </PropertyGroup>
        </ExposedProperties>
      </SubProxy>
    </Extension>

    <Extension name="UnstructuredGridRepresentation">
      <RepresentationType subproxy="AnimatedStreamlineRepresentation"
                          text="Animated Streamline" />
      <SubProxy>
        <Proxy name="AnimatedStreamlineRepresentation"
               proxygroup="representations"
               proxyname="AnimatedStreamlineRepresentation" />
        <ShareProperties subproxy="SurfaceRepresentation">
          <Exception name="Input" />
          <Exception name="Visibility" />
          <Exception name="Representation" />
        </ShareProperties>
        <ExposedProperties>
          <PropertyGroup label="Animated Streamline">
            <Property name="Animate" exposed_name="AS_Animate" />
            <Property name="IntegrationScale" exposed_name="AS_IntegrationScale" />
            <Property name="TimeScale" exposed_name="AS_TimeScale" />
            <Property name="OpacityScale" exposed_name="AS_OpacityScale" />
            <Property name="Trunc" exposed_name="AS_Trunc" />
            <Property name="Pow" exposed_name="AS_Pow" />
            <Property name="AnimationCoordinateArray" exposed_name="AS_AnimationCoordinateArray" />
            <Hints>
              <PropertyWidgetDecorator type="GenericDecorator"
                                       mode="visibility"
                                       property="Representation"
                                       value="Animated Streamline" />
            </Hints>
          </PropertyGroup>
        </ExposedProperties>
      </SubProxy>
    </Extension>

    <Extension name="UniformGridRepresentation">
      <RepresentationType subproxy="AnimatedStreamlineRepresentation"
                          text="Animated Streamline" />
      <SubProxy>
        <Proxy name="AnimatedStreamlineRepresentation"
               proxygroup="representations"
               proxyname="AnimatedStreamlineRepresentation" />
        <ShareProperties subproxy="SurfaceRepresentation">
          <Exception name="Input" />
          <Exception name="Visibility" />
          <Exception name="Representation" />
        </ShareProperties>
        <ExposedProperties>
          <PropertyGroup label="Animated Streamline">
            <Property name="Animate" exposed_name="AS_Animate" />
            <Property name="IntegrationScale" exposed_name="AS_IntegrationScale" />
            <Property name="TimeScale" exposed_name="AS_TimeScale" />
            <Property name="OpacityScale" exposed_name="AS_OpacityScale" />
            <Property name="Trunc" exposed_name="AS_Trunc" />
            <Property name="Pow" exposed_name="AS_Pow" />
            <Property name="AnimationCoordinateArray" exposed_name="AS_AnimationCoordinateArray" />
            <Hints>
              <PropertyWidgetDecorator type="GenericDecorator"
                                       mode="visibility"
                                       property="Representation"
                                       value="Animated Streamline" />
            </Hints>
          </PropertyGroup>
        </ExposedProperties>
      </SubProxy>
    </Extension>

    <Extension name="StructuredGridRepresentation">
      <RepresentationType subproxy="AnimatedStreamlineRepresentation"
                          text="Animated Streamline" />
      <SubProxy>
        <Proxy name="AnimatedStreamlineRepresentation"
               proxygroup="representations"
               proxyname="AnimatedStreamlineRepresentation" />
        <ShareProperties subproxy="SurfaceRepresentation">
          <Exception name="Input" />
          <Exception name="Visibility" />
          <Exception name="Representation" />
        </ShareProperties>
        <ExposedProperties>
          <PropertyGroup label="Animated Streamline">
            <Property name="Animate" exposed_name="AS_Animate" />
            <Property name="IntegrationScale" exposed_name="AS_IntegrationScale" />
            <Property name="TimeScale" exposed_name="AS_TimeScale" />
            <Property name="OpacityScale" exposed_name="AS_OpacityScale" />
            <Property name="Trunc" exposed_name="AS_Trunc" />
            <Property name="Pow" exposed_name="AS_Pow" />
            <Property name="AnimationCoordinateArray" exposed_name="AS_AnimationCoordinateArray" />
            <Hints>
              <PropertyWidgetDecorator type="GenericDecorator"
                                       mode="visibility"
                                       property="Representation"
                                       value="Animated Streamline" />
            </Hints>
          </PropertyGroup>
        </ExposedProperties>
      </SubProxy>
    </Extension>
  </ProxyGroup>
</ServerManagerConfiguration>

