<?xml version="1.0" ?>
<ServerManagerConfiguration>
  <ProxyGroup name="filters">
    <SourceProxy class="vtkSHYXAdaptiveIsotropicRemesherTest"
                 label="SHYX Adaptive Isotropic Remesher Test"
                 name="SHYXAdaptiveIsotropicRemesherTest">
      <Documentation short_help="Preview dual adaptive sizing maps (global/feature) without remeshing.">
        Builds the same CGAL constrained-edge graph and evaluates the dual per-vertex sizing maps
        (VespaAdaptiveSizeGlobal / VespaAdaptiveSizeFeature) used when FeatureSizingStandAlone is ON
        in vtkSHYXAdaptiveIsotropicRemesher. Input geometry is unchanged (no isotropic remeshing,
        no smooth_shape). Requires positive Feature Min/Max Edge Length and Feature Adaptive Tolerance
        plus global sizing parameters.

        With vtkSelection on port 1 (default remesh region source), or a scalar range on the input,
        curvature for the sizing field uses the same expanded patch as the remesher (CGAL
        Face_filtered_graph semantics).

        Outputs:
          0  Copy of the input surface with point arrays VespaAdaptiveSizeGlobal and
             VespaAdaptiveSizeFeature.
          1  Sharp/feature constraint edges as lines (same detection pipeline as the remesher when
             Detect feature edges is ON); never adds vertex cells.
          2  Input geometry restricted by the feature mask threshold (same as remesher).
          3  Empty (no remeshed mask patch).

        Requires CGAL 6.0+.
      </Documentation>

      <OutputPort name="Remeshed surface"      index="0" id="port0"/>
      <OutputPort name="Sharp features"        index="1" id="port1"/>
      <OutputPort name="Mask patch (input)"    index="2" id="port2"/>
      <OutputPort name="Mask patch (remeshed)" index="3" id="port3"/>

      <!-- =================================================================
                                       INPUTS
           ================================================================= -->
      <InputProperty name="Input"
                     command="SetInputConnection">
        <ProxyGroupDomain name="groups">
          <Group name="sources"/>
          <Group name="filters"/>
        </ProxyGroupDomain>
        <DataTypeDomain name="input_type">
          <DataType value="vtkPolyData"/>
        </DataTypeDomain>
        <InputArrayDomain name="feature_mask_arrays" optional="1"/>
        <InputArrayDomain name="remesh_range_arrays" optional="1"/>
      </InputProperty>

      <InputProperty name="Selection" label="Selection"
                     command="SetSourceConnection">
        <ProxyGroupDomain name="groups">
          <Group name="sources"/>
          <Group name="filters"/>
        </ProxyGroupDomain>
        <DataTypeDomain name="input_type">
          <DataType value="vtkSelection"/>
        </DataTypeDomain>
        <Documentation>
          Optional vtkSelection used when Remesh region source is "Selection (port 1)" (default).
          Scalar range mode ignores this port for the expanded patch; see vtkSHYXAdaptiveIsotropicRemesher.
        </Documentation>
        <Hints>
          <SelectionInput/>
        </Hints>
      </InputProperty>

      <IntVectorProperty command="SetRemeshRegionMode"
                         name="RemeshRegionMode"
                         label="Remesh region source"
                         number_of_elements="1"
                         default_values="0"
                         animateable="0">
        <EnumerationDomain name="remesh_region_enum">
          <Entry text="Selection (port 1)" value="0"/>
          <Entry text="Scalar range on input" value="1"/>
        </EnumerationDomain>
        <Documentation>
          Same meaning as vtkSHYXAdaptiveIsotropicRemesher: patch used for Face_filtered_graph sizing preview.
        </Documentation>
      </IntVectorProperty>

      <StringVectorProperty name="RemeshRangeArrayName"
                            label="Range array"
                            command="SetRemeshRangeArrayName"
                            number_of_elements="1"
                            default_values=""
                            animateable="0">
        <ArrayListDomain name="remesh_range_list"
                         input_domain_name="remesh_range_arrays">
          <RequiredProperties>
            <Property name="Input" function="Input"/>
          </RequiredProperties>
        </ArrayListDomain>
        <Documentation>
          Point- or cell array for scalar range mode (same rules as the main remesher).
        </Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="RemeshRegionMode"
                                   value="1"/>
          <ArraySelectionWidget/>
        </Hints>
      </StringVectorProperty>

      <DoubleVectorProperty command="SetRemeshRangeMin"
                            name="RemeshRangeMin"
                            label="Remesh range min"
                            number_of_elements="1"
                            default_values="0"
                            animateable="1">
        <DoubleRangeDomain name="range" min="-1e308" max="1e308"/>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="RemeshRegionMode"
                                   value="1"/>
        </Hints>
      </DoubleVectorProperty>

      <DoubleVectorProperty command="SetRemeshRangeMax"
                            name="RemeshRangeMax"
                            label="Remesh range max"
                            number_of_elements="1"
                            default_values="1"
                            animateable="1">
        <DoubleRangeDomain name="range" min="-1e308" max="1e308"/>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="RemeshRegionMode"
                                   value="1"/>
        </Hints>
      </DoubleVectorProperty>

      <IntVectorProperty command="SetRemeshRangeAllScalars"
                         name="RemeshRangeAllScalars"
                         label="Range: all corners (points)"
                         number_of_elements="1"
                         default_values="0"
                         animateable="0">
        <BooleanDomain name="bool"/>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="RemeshRegionMode"
                                   value="1"/>
        </Hints>
      </IntVectorProperty>

      <PropertyGroup label="Remesh region">
        <Property name="RemeshRegionMode"/>
        <Property name="RemeshRangeArrayName"/>
        <Property name="RemeshRangeMin"/>
        <Property name="RemeshRangeMax"/>
        <Property name="RemeshRangeAllScalars"/>
      </PropertyGroup>

      <!-- =================================================================
                                       SIZING
           ================================================================= -->
      <DoubleVectorProperty command="SetMinEdgeLength"
                            name="MinEdgeLength"
                            label="Min edge length"
                            number_of_elements="1"
                            default_values="0">
        <BoundsDomain mode="scaled_extent" name="bounds_min" scale_factor="0.001">
          <RequiredProperties>
            <Property function="Input" name="Input"/>
          </RequiredProperties>
        </BoundsDomain>
        <Documentation>
          Minimum edge length; must be &gt; 0. ParaView BoundsDomain (scaled_extent 0.001)
          suggests 0.1% of the input axis-aligned bounding box longest side; use Scale/Reset
          next to the property.
        </Documentation>
      </DoubleVectorProperty>

      <DoubleVectorProperty command="SetMaxEdgeLength"
                            name="MaxEdgeLength"
                            label="Max edge length"
                            number_of_elements="1"
                            default_values="0">
        <BoundsDomain mode="scaled_extent" name="bounds_max" scale_factor="0.05">
          <RequiredProperties>
            <Property function="Input" name="Input"/>
          </RequiredProperties>
        </BoundsDomain>
        <Documentation>
          Maximum edge length; must be &gt; Min edge length. ParaView BoundsDomain
          (scaled_extent 0.05) suggests 5% of the input axis-aligned bounding box longest side;
          use Scale/Reset next to the property.
        </Documentation>
      </DoubleVectorProperty>

      <DoubleVectorProperty command="SetAdaptiveTolerance"
                            name="AdaptiveTolerance"
                            label="Adaptive tolerance"
                            number_of_elements="1"
                            default_values="0.01">
        <DoubleRangeDomain name="range" min="0"/>
        <Documentation>
          CGAL Adaptive_sizing_field tolerance. Smaller values tend to refine more within the
          Min/Max edge length bounds.
        </Documentation>
      </DoubleVectorProperty>

      <IntVectorProperty command="SetFeatureSizingStandAlone"
                         name="FeatureSizingStandAlone"
                         label="Feature sizing stand-alone"
                         number_of_elements="1"
                         default_values="0"
                         animateable="0">
        <BooleanDomain name="bool"/>
        <Documentation>
          When OFF (default), the whole surface uses the global Min/Max edge length and Adaptive
          tolerance above; behavior is identical to the previous version.
          When ON, feature/constrained edges (sharp + feature-mask region/boundary + selection
          boundary) use a SEPARATE Adaptive_sizing_field built from Feature min/max edge length
          and Feature adaptive tolerance, while the rest of the surface keeps using the global
          field. Other options (Protect / Collapse / Relax constraints, Allow split / collapse /
          flip, etc.) are unaffected. With Protect constraints ON, the feature field has no
          practical effect because feature edges are not split nor collapsed (only the
          tangential-relaxation target at their endpoints is altered).
        </Documentation>
      </IntVectorProperty>

      <DoubleVectorProperty command="SetFeatureMinEdgeLength"
                            name="FeatureMinEdgeLength"
                            label="Feature min edge length"
                            number_of_elements="1"
                            default_values="0">
        <BoundsDomain mode="scaled_extent" name="bounds_feat_min" scale_factor="0.001">
          <RequiredProperties>
            <Property function="Input" name="Input"/>
          </RequiredProperties>
        </BoundsDomain>
        <Documentation>
          Minimum edge length on feature/constrained edges (used only when Feature sizing
          stand-alone is ON); must be &gt; 0. ParaView BoundsDomain (scaled_extent 0.001)
          suggests 0.1% of the input axis-aligned bounding box longest side.
        </Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="FeatureSizingStandAlone"
                                   value="1"/>
        </Hints>
      </DoubleVectorProperty>

      <DoubleVectorProperty command="SetFeatureMaxEdgeLength"
                            name="FeatureMaxEdgeLength"
                            label="Feature max edge length"
                            number_of_elements="1"
                            default_values="0">
        <BoundsDomain mode="scaled_extent" name="bounds_feat_max" scale_factor="0.05">
          <RequiredProperties>
            <Property function="Input" name="Input"/>
          </RequiredProperties>
        </BoundsDomain>
        <Documentation>
          Maximum edge length on feature/constrained edges (used only when Feature sizing
          stand-alone is ON); must be &gt; Feature min edge length. ParaView BoundsDomain
          (scaled_extent 0.05) suggests 5% of the input axis-aligned bounding box longest side.
        </Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="FeatureSizingStandAlone"
                                   value="1"/>
        </Hints>
      </DoubleVectorProperty>

      <DoubleVectorProperty command="SetFeatureAdaptiveTolerance"
                            name="FeatureAdaptiveTolerance"
                            label="Feature adaptive tolerance"
                            number_of_elements="1"
                            default_values="0.01">
        <DoubleRangeDomain name="range" min="0"/>
        <Documentation>
          CGAL Adaptive_sizing_field tolerance for feature/constrained edges (used only when
          Feature sizing stand-alone is ON). Smaller values refine feature edges more within
          their Feature min/max bounds.
        </Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="FeatureSizingStandAlone"
                                   value="1"/>
        </Hints>
      </DoubleVectorProperty>

      <IntVectorProperty command="SetFeatureSizingUsePolylineCurvature"
                         name="FeatureSizingUsePolylineCurvature"
                         label="Feature sizing: polyline curvature"
                         number_of_elements="1"
                         default_values="0"
                         animateable="0">
        <BooleanDomain name="bool"/>
        <Documentation>
          When Feature sizing stand-alone is ON: if ON, target edge lengths on constrained
          feature edges use **3D polyline (Menger) curvature** at crease vertices instead of
          surface principal curvatures. If OFF (default), feature sizing uses the same
          interpolated_corrected surface curvatures as the global field (previous behavior).
        </Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="FeatureSizingStandAlone"
                                   value="1"/>
        </Hints>
      </IntVectorProperty>

      <PropertyGroup label="Sizing">
        <Property name="MinEdgeLength"/>
        <Property name="MaxEdgeLength"/>
        <Property name="AdaptiveTolerance"/>
        <Property name="FeatureSizingStandAlone"/>
        <Property name="FeatureMinEdgeLength"/>
        <Property name="FeatureMaxEdgeLength"/>
        <Property name="FeatureAdaptiveTolerance"/>
        <Property name="FeatureSizingUsePolylineCurvature"/>
      </PropertyGroup>

      <!-- =================================================================
                                    ITERATIONS
           ================================================================= -->
      <IntVectorProperty command="SetNumberOfIterations"
                         name="NumberOfIterations"
                         label="Remesh iterations"
                         number_of_elements="1"
                         default_values="3">
        <IntRangeDomain name="range" min="1" max="20"/>
        <Documentation>
          Number of CGAL isotropic_remeshing iterations.
        </Documentation>
      </IntVectorProperty>

      <IntVectorProperty command="SetNumberOfRelaxationSteps"
                         name="NumberOfRelaxationSteps"
                         label="Relaxation steps"
                         number_of_elements="1"
                         default_values="3"
                         panel_visibility="advanced">
        <IntRangeDomain name="range" min="0" max="20"/>
        <Documentation>
          CGAL vertex-relocation steps per remesh iteration (higher = smoother surface;
          0 disables relaxation).
        </Documentation>
      </IntVectorProperty>

      <PropertyGroup label="Iterations">
        <Property name="NumberOfIterations"/>
        <Property name="NumberOfRelaxationSteps"/>
      </PropertyGroup>

      <!-- =================================================================
                              FEATURE EDGES & FEATURE MASK
           ================================================================= -->
      <IntVectorProperty command="SetDetectFeatureEdges"
                         name="DetectFeatureEdges"
                         label="Detect feature edges"
                         number_of_elements="1"
                         default_values="1"
                         animateable="0">
        <BooleanDomain name="bool"/>
        <Documentation>
          Master switch for sharp-edge / feature-mask constraints. When ON (default), CGAL
          detect_sharp_edges (with Protection angle / Sharp side filter) and feature-mask region
          / boundary contributions are added to edge_is_constrained_map for isotropic_remeshing
          and to vertex_is_constrained_map for smooth_shape. When OFF, none of those sources
          contribute; remesh and smooth_shape only see vtkSelection-boundary constraints (when a
          selection input is connected). vtkSelection behavior is independent of this toggle.
          Output port 1 is empty when OFF.
        </Documentation>
      </IntVectorProperty>

      <DoubleVectorProperty command="SetProtectAngle"
                            name="ProtectAngle"
                            label="Protection angle"
                            number_of_elements="1"
                            default_values="70">
        <DoubleRangeDomain name="range" min="0" max="180"/>
        <Documentation>
          Sharp-edge angle threshold in degrees (CGAL detect_sharp_edges). Endpoints of detected
          sharp edges are protected during remesh and pinned during smooth_shape.
        </Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="enabled_state"
                                   property="DetectFeatureEdges"
                                   value="1"/>
        </Hints>
      </DoubleVectorProperty>

      <IntVectorProperty command="SetSharpFeatureSideFilter"
                         name="SharpFeatureSideFilter"
                         label="Sharp side filter"
                         number_of_elements="1"
                         default_values="0"
                         animateable="0"
                         panel_visibility="advanced">
        <EnumerationDomain name="enum">
          <Entry text="None" value="0"/>
          <Entry text="Exclude concave (signed &lt; 0)" value="1"/>
          <Entry text="Exclude convex (signed &gt; 0)"  value="2"/>
        </EnumerationDomain>
        <Documentation>
          Optional filter on interior sharp edges after CGAL detect_sharp_edges, using signed
          dihedral angle (approximate_dihedral_angle). Excludes concave (signed &lt; 0) or convex
          (signed &gt; 0) from remesh / shape constraints and from port 1. Boundary edges are
          unchanged. If convex/concave looks swapped, flip mesh orientation or pick the other
          entry.
        </Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="enabled_state"
                                   property="DetectFeatureEdges"
                                   value="1"/>
        </Hints>
      </IntVectorProperty>

      <IntVectorProperty command="SetFeatureMaskEnabled"
                         name="FeatureMaskEnabled"
                         label="Use feature mask"
                         number_of_elements="1"
                         default_values="0"
                         animateable="0">
        <BooleanDomain name="bool"/>
        <Documentation>
          When ON: threshold input faces to port 2; port 1 sharp features are computed only on
          that patch; on the full surface, sharp edges are intersected with the mask for CGAL
          remesh / smooth_shape. Choose a point- or cell-centered array, a threshold (tuple
          magnitude &gt; threshold), and the optional All Scalars flag for point arrays.
          Has no effect when Detect feature edges is OFF.
        </Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="enabled_state"
                                   property="DetectFeatureEdges"
                                   value="1"/>
        </Hints>
      </IntVectorProperty>

      <StringVectorProperty name="FeatureMaskArrayName"
                            label="Array"
                            command="SetFeatureMaskArrayName"
                            number_of_elements="1"
                            default_values=""
                            animateable="0">
        <ArrayListDomain name="feature_mask_list"
                         input_domain_name="feature_mask_arrays">
          <RequiredProperties>
            <Property name="Input" function="Input"/>
          </RequiredProperties>
        </ArrayListDomain>
        <Documentation>
          Name of a point- or cell-centered array. If both exist with the same name, cell data
          is used. Tuple magnitude must be &gt; Threshold for a cell (or per-point corner) to
          pass.
        </Documentation>
        <Hints>
          <PropertyWidgetDecorator type="CompositeDecorator">
            <Expression type="and">
              <PropertyWidgetDecorator type="GenericDecorator"
                                       mode="visibility"
                                       property="FeatureMaskEnabled"
                                       value="1"/>
              <PropertyWidgetDecorator type="GenericDecorator"
                                       mode="enabled_state"
                                       property="DetectFeatureEdges"
                                       value="1"/>
            </Expression>
          </PropertyWidgetDecorator>
          <ArraySelectionWidget/>
        </Hints>
      </StringVectorProperty>

      <DoubleVectorProperty command="SetFeatureMaskThreshold"
                            name="FeatureMaskThreshold"
                            label="Threshold"
                            number_of_elements="1"
                            default_values="0"
                            animateable="1">
        <DoubleRangeDomain name="range" min="-1e308" max="1e308"/>
        <Documentation>
          Cells pass when tuple magnitude is strictly greater than this value (scalar or vector
          magnitude). Typical: 0 to keep values &gt; 0.
        </Documentation>
        <Hints>
          <PropertyWidgetDecorator type="CompositeDecorator">
            <Expression type="and">
              <PropertyWidgetDecorator type="GenericDecorator"
                                       mode="visibility"
                                       property="FeatureMaskEnabled"
                                       value="1"/>
              <PropertyWidgetDecorator type="GenericDecorator"
                                       mode="enabled_state"
                                       property="DetectFeatureEdges"
                                       value="1"/>
            </Expression>
          </PropertyWidgetDecorator>
        </Hints>
      </DoubleVectorProperty>

      <IntVectorProperty command="SetFeatureMaskAllScalars"
                         name="FeatureMaskAllScalars"
                         label="All scalars"
                         number_of_elements="1"
                         default_values="0"
                         animateable="0">
        <BooleanDomain name="bool"/>
        <Documentation>
          When the chosen array is point-centered: if ON, every corner of a cell must pass the
          magnitude test; if OFF, one passing corner is enough (vtkThreshold-style). Ignored
          when the array resolves to cell data.
        </Documentation>
        <Hints>
          <PropertyWidgetDecorator type="CompositeDecorator">
            <Expression type="and">
              <PropertyWidgetDecorator type="GenericDecorator"
                                       mode="visibility"
                                       property="FeatureMaskEnabled"
                                       value="1"/>
              <PropertyWidgetDecorator type="GenericDecorator"
                                       mode="enabled_state"
                                       property="DetectFeatureEdges"
                                       value="1"/>
            </Expression>
          </PropertyWidgetDecorator>
        </Hints>
      </IntVectorProperty>

      <PropertyGroup label="Feature edges &amp; mask">
        <Property name="DetectFeatureEdges"/>
        <Property name="ProtectAngle"/>
        <Property name="SharpFeatureSideFilter"/>
        <Property name="FeatureMaskEnabled"/>
        <Property name="FeatureMaskArrayName"/>
        <Property name="FeatureMaskThreshold"/>
        <Property name="FeatureMaskAllScalars"/>
      </PropertyGroup>

      <!-- =================================================================
                              REMESH CONSTRAINTS (CGAL)
           ================================================================= -->
      <IntVectorProperty command="SetRemeshProtectConstraints"
                         name="RemeshProtectConstraints"
                         label="Protect constraints"
                         number_of_elements="1"
                         default_values="1">
        <BooleanDomain name="bool"/>
        <Documentation>
          CGAL `protect_constraints`. When ON, feature edges are neither split nor collapsed.
          When OFF, constrained edges may be split or collapsed per CGAL (subject to
          Collapse constraints below).
        </Documentation>
      </IntVectorProperty>

      <IntVectorProperty command="SetRemeshCollapseConstraints"
                         name="RemeshCollapseConstraints"
                         label="Collapse constraints"
                         number_of_elements="1"
                         default_values="1">
        <BooleanDomain name="bool"/>
        <Documentation>
          CGAL `collapse_constraints`. When Protect constraints is OFF, allows collapsing
          constrained edges. Ignored by CGAL when Protect constraints is ON.
        </Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="enabled_state"
                                   property="RemeshProtectConstraints"
                                   value="0"/>
        </Hints>
      </IntVectorProperty>

      <IntVectorProperty command="SetRemeshRelaxConstraints"
                         name="RemeshRelaxConstraints"
                         label="Relax constraints"
                         number_of_elements="1"
                         default_values="0">
        <BooleanDomain name="bool"/>
        <Documentation>
          CGAL `relax_constraints`. When ON, endpoints of constrained and boundary edges may
          move along constrained polylines during tangential relaxation.
        </Documentation>
      </IntVectorProperty>

      <PropertyGroup label="Remesh constraints (CGAL)">
        <Property name="RemeshProtectConstraints"/>
        <Property name="RemeshCollapseConstraints"/>
        <Property name="RemeshRelaxConstraints"/>
      </PropertyGroup>

      <!-- =================================================================
                              REMESH OPERATIONS (advanced)
           ================================================================= -->
      <IntVectorProperty command="SetRemeshDoSplit"
                         name="RemeshDoSplit"
                         label="Allow split"
                         number_of_elements="1"
                         default_values="1"
                         panel_visibility="advanced">
        <BooleanDomain name="bool"/>
        <Documentation>CGAL `isotropic_remeshing::do_split`.</Documentation>
      </IntVectorProperty>

      <IntVectorProperty command="SetRemeshDoCollapse"
                         name="RemeshDoCollapse"
                         label="Allow collapse"
                         number_of_elements="1"
                         default_values="1"
                         panel_visibility="advanced">
        <BooleanDomain name="bool"/>
        <Documentation>CGAL `isotropic_remeshing::do_collapse`.</Documentation>
      </IntVectorProperty>

      <IntVectorProperty command="SetRemeshDoFlip"
                         name="RemeshDoFlip"
                         label="Allow flip"
                         number_of_elements="1"
                         default_values="1"
                         panel_visibility="advanced">
        <BooleanDomain name="bool"/>
        <Documentation>CGAL `isotropic_remeshing::do_flip`.</Documentation>
      </IntVectorProperty>

      <PropertyGroup label="Remesh operations (CGAL)" panel_visibility="advanced">
        <Property name="RemeshDoSplit"/>
        <Property name="RemeshDoCollapse"/>
        <Property name="RemeshDoFlip"/>
      </PropertyGroup>

      <!-- =================================================================
                          POST-REMESH SHAPE SMOOTHING
           ================================================================= -->
      <IntVectorProperty command="SetShapeSmoothingIterations"
                         name="ShapeSmoothingIterations"
                         label="Iterations"
                         number_of_elements="1"
                         default_values="0">
        <IntRangeDomain name="range" min="0" max="100"/>
        <Documentation>
          Post-remesh CGAL smooth_shape iterations. 0 disables. Sharp-edge vertices
          (Protection Angle) and Feature-Mask boundary vertices stay fixed.
        </Documentation>
      </IntVectorProperty>

      <DoubleVectorProperty command="SetShapeSmoothingTimeStep"
                            name="ShapeSmoothingTimeStep"
                            label="Time step"
                            number_of_elements="1"
                            default_values="0.0001">
        <DoubleRangeDomain name="range" min="1e-12" max="1"/>
        <Documentation>
          CGAL smooth_shape time step (smoothing speed). Typical range about 1e-6 to 1.
          Used only when Shape-smoothing Iterations &gt; 0.
        </Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="enabled_state"
                                   property="ShapeSmoothingIterations"
                                   value="0"
                                   inverse="1"/>
        </Hints>
      </DoubleVectorProperty>

      <PropertyGroup label="Post-remesh smoothing (smooth_shape)">
        <Property name="ShapeSmoothingIterations"/>
        <Property name="ShapeSmoothingTimeStep"/>
      </PropertyGroup>

      <!-- =================================================================
                                       OUTPUT
           ================================================================= -->
      <IntVectorProperty name="UseUpdateAttributes"
                         command="SetUpdateAttributes"
                         label="Interpolate attributes"
                         number_of_elements="1"
                         default_values="1">
        <BooleanDomain name="bool"/>
        <Documentation>
          If ON, point/cell data are interpolated onto the new mesh.
        </Documentation>
      </IntVectorProperty>

      <PropertyGroup label="Output">
        <Property name="UseUpdateAttributes"/>
      </PropertyGroup>

      <Hints>
        <ShowInMenu category="SHYX" icon=":/VESPA/SHYX_Adaptive_Isotropic_Remesher.png"/>
      </Hints>

    </SourceProxy>
  </ProxyGroup>
</ServerManagerConfiguration>
