<ServerManagerConfiguration>
  <ProxyGroup name="filters">
    <SourceProxy name="SHYXSelectionFillAlphaReunionFilter"
                 class="vtkSHYXSelectionFillAlphaReunionFilter"
                 label="SHYX Selection: Fill, Alpha Wrap, Union">
      <Documentation short_help="Split by selection, hole-fill both, Alpha wrap selection, CGAL union with face origin, then local bridge remesh/smooth or fair.">
        Splits the surface into the selected and unselected regions, fills boundary holes (CGAL) on
        each part, runs Alpha Wrapping on the selected part (CGAL 5.5+), and merges the two
        closed-oriented surfaces with a CGAL PMP boolean union that tracks which faces came from
        the Alpha-Wrapped mesh. Those faces are marked exactly (no distance heuristic). Cleanup
        either dilates the full AW region or (checkbox) starts from the AW/original boolean seam,
        then locally remeshes and post-smooths (smooth_shape MCF or fair with C0–C2 at the patch
        boundary). When the unselected part is empty (entire surface selected), only the selected
        path is output. Use Selection on port 1, or a cell data mask (SelectionCellArrayName) like
        other SHYX selection tools.
      </Documentation>

      <InputProperty name="Input" command="SetInputConnection">
        <ProxyGroupDomain name="groups">
          <Group name="sources"/>
          <Group name="filters"/>
        </ProxyGroupDomain>
        <DataTypeDomain name="input_type">
          <DataType value="vtkPolyData"/>
        </DataTypeDomain>
      </InputProperty>

      <InputProperty command="SetSourceConnection"
                     name="Selection"
                     label="Selection">
        <ProxyGroupDomain name="groups">
          <Group name="sources"/>
          <Group name="filters"/>
        </ProxyGroupDomain>
        <DataTypeDomain name="input_type">
          <DataType value="vtkSelection"/>
        </DataTypeDomain>
        <Documentation>
          Cells to treat as the region that is hole-filled and Alpha-wrapped; the complement is
          hole-filled and then unioned.
        </Documentation>
        <Hints>
          <SelectionInput/>
        </Hints>
      </InputProperty>

      <StringVectorProperty name="SelectionCellArrayName"
                            command="SetSelectionCellArrayName"
                            number_of_elements="1"
                            default_values=""
                            panel_visibility="advanced">
        <Documentation>
          Optional: when Selection is not connected, name of a cell data array on the mesh. Same
          rule as SHYX Delete Selected Cells: integral non-zero or float &gt; 0.5 selects a cell.
        </Documentation>
      </StringVectorProperty>

      <IntVectorProperty command="SetFairingContinuity"
                         name="FairingContinuity"
                         label="Fairing (hole fill)"
                         number_of_elements="1"
                         default_values="1"
                         animateable="0">
        <IntRangeDomain name="range" min="0" max="2"/>
        <Documentation>
          Continuity for CGAL hole fill on both sub-meshes (0 / 1 / 2), same as SHYX Hole Fill.
        </Documentation>
      </IntVectorProperty>

      <IntVectorProperty command="SetSkipAlphaWrapping"
                         name="SkipAlphaWrapping"
                         label="Skip Alpha wrap (selected only)"
                         number_of_elements="1"
                         default_values="0"
                         panel_visibility="advanced"
                         animateable="0">
        <BooleanDomain name="bool"/>
        <Documentation>
          If on, the selected part is only hole-filled (no Alpha Wrapping).
        </Documentation>
      </IntVectorProperty>

      <IntVectorProperty command="SetAbsoluteThresholds"
                         name="AbsoluteThresholds"
                         label="Alpha wrap: absolute Alpha/Offset"
                         number_of_elements="1"
                         default_values="0"
                         panel_visibility="advanced"
                         animateable="0">
        <BooleanDomain name="bool"/>
        <Documentation>
          If off, Alpha and Offset are percentages of the mesh length (see VESPA Alpha Wrapping).
        </Documentation>
      </IntVectorProperty>

      <DoubleVectorProperty command="SetAlpha"
                            name="Alpha"
                            label="Alpha"
                            number_of_elements="1"
                            default_values="4.0"
                            panel_visibility="advanced"
                            animateable="1">
        <Documentation>Alpha wrap parameter (maximum circumradius of faces in the result).</Documentation>
      </DoubleVectorProperty>

      <DoubleVectorProperty command="SetOffset"
                            name="Offset"
                            label="Offset"
                            number_of_elements="1"
                            default_values="0.05"
                            panel_visibility="advanced"
                            animateable="1">
        <Documentation>Alpha wrap offset (dilatation / shrink factor depending on context).</Documentation>
      </DoubleVectorProperty>

      <IntVectorProperty command="SetThrowOnSelfIntersection"
                         name="ThrowOnSelfIntersection"
                         label="Boolean: throw on self-intersection"
                         number_of_elements="1"
                         default_values="0"
                         panel_visibility="advanced"
                         animateable="0">
        <BooleanDomain name="bool"/>
      </IntVectorProperty>

      <IntVectorProperty command="SetOrientToBoundVolumeWhenNeeded"
                         name="OrientToBoundVolumeWhenNeeded"
                         label="Boolean: orient if volume unclear"
                         number_of_elements="1"
                         default_values="1"
                         panel_visibility="advanced"
                         animateable="0">
        <BooleanDomain name="bool"/>
      </IntVectorProperty>

      <IntVectorProperty name="UseUpdateAttributes"
                         command="SetUpdateAttributes"
                         label="Interpolate attributes (from full input)"
                         number_of_elements="1"
                         default_values="1"
                         panel_visibility="advanced"
                         animateable="0">
        <BooleanDomain name="bool"/>
        <Documentation>
          Probe the original full surface onto the merged result.
        </Documentation>
      </IntVectorProperty>

      <IntVectorProperty command="SetEnableBridgeCleanup"
                         name="EnableBridgeCleanup"
                         label="Bridge cleanup after union"
                         number_of_elements="1"
                         default_values="1"
                         animateable="0">
        <BooleanDomain name="bool"/>
        <Documentation>
          Mark faces that originated from the Alpha-Wrapped mesh during CGAL corefinement union
          (precise provenance), seed/dilate a cleanup patch (whole AW region or union seam), then
          run a local isotropic remesh + constrained smooth_shape (MCF) or fair.
        </Documentation>
      </IntVectorProperty>

      <IntVectorProperty command="SetBridgeDilateFromSeam"
                         name="BridgeDilateFromSeam"
                         label="Bridge: dilate from union seam"
                         number_of_elements="1"
                         default_values="0"
                         animateable="0">
        <BooleanDomain name="bool"/>
        <Documentation>
          Off (default): expand from all Alpha-Wrap faces, then remesh/smooth that patch.
          On: seed only faces on the AW/original boolean seam, expand by dilate layers, then
          remesh/smooth — a band around the union junction instead of the whole AW region.
        </Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="enabled_state"
                                   property="EnableBridgeCleanup"
                                   value="1"/>
        </Hints>
      </IntVectorProperty>

      <IntVectorProperty command="SetBridgeDilateLayers"
                         name="BridgeDilateLayers"
                         label="Bridge: dilate layers"
                         number_of_elements="1"
                         default_values="3"
                         animateable="0">
        <IntRangeDomain name="range" min="0" max="64"/>
        <Documentation>
          Face-ring expansion of the cleanup seed (all AW faces, or the union seam when
          BridgeDilateFromSeam is on).
        </Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="enabled_state"
                                   property="EnableBridgeCleanup"
                                   value="1"/>
        </Hints>
      </IntVectorProperty>

      <DoubleVectorProperty command="SetBridgeTargetEdgeLength"
                            name="BridgeTargetEdgeLength"
                            label="Bridge: remesh target edge length"
                            number_of_elements="1"
                            default_values="-1"
                            panel_visibility="advanced"
                            animateable="0">
        <Documentation>
          Target edge length for local isotropic remesh. &lt;= 0 uses the mean edge length of the
          dilated cleanup patch.
        </Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="enabled_state"
                                   property="EnableBridgeCleanup"
                                   value="1"/>
        </Hints>
      </DoubleVectorProperty>

      <IntVectorProperty command="SetBridgeRemeshIterations"
                         name="BridgeRemeshIterations"
                         label="Bridge: remesh iterations"
                         number_of_elements="1"
                         default_values="3"
                         panel_visibility="advanced"
                         animateable="0">
        <IntRangeDomain name="range" min="1" max="50"/>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="enabled_state"
                                   property="EnableBridgeCleanup"
                                   value="1"/>
        </Hints>
      </IntVectorProperty>

      <IntVectorProperty command="SetBridgeRemeshRelaxationSteps"
                         name="BridgeRemeshRelaxationSteps"
                         label="Bridge: remesh relaxation steps"
                         number_of_elements="1"
                         default_values="3"
                         panel_visibility="advanced"
                         animateable="0">
        <IntRangeDomain name="range" min="0" max="50"/>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="enabled_state"
                                   property="EnableBridgeCleanup"
                                   value="1"/>
        </Hints>
      </IntVectorProperty>

      <IntVectorProperty command="SetBridgeSmoothMethod"
                         name="BridgeSmoothMethod"
                         label="Bridge: post-remesh method"
                         number_of_elements="1"
                         default_values="2"
                         panel_visibility="advanced"
                         animateable="0">
        <EnumerationDomain name="enum">
          <Entry text="None (remesh only)" value="0"/>
          <Entry text="Shape MCF (smooth_shape)" value="1"/>
          <Entry text="Fair" value="2"/>
        </EnumerationDomain>
        <Documentation>
          After remesh, optionally smooth the cleanup-patch interior with CGAL smooth_shape
          (mean curvature flow, C0 at the seam) or fair (C0–C2 via Bridge Fair Continuity).
          None leaves the remeshed patch as-is.
        </Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="enabled_state"
                                   property="EnableBridgeCleanup"
                                   value="1"/>
        </Hints>
      </IntVectorProperty>

      <IntVectorProperty command="SetBridgeSmoothIterations"
                         name="BridgeSmoothIterations"
                         label="Bridge: shape smooth iterations"
                         number_of_elements="1"
                         default_values="8"
                         panel_visibility="advanced"
                         animateable="0">
        <IntRangeDomain name="range" min="0" max="50"/>
        <Documentation>
          CGAL smooth_shape iterations on the cleanup patch (0 = no MCF motion). Only used when
          Bridge post-remesh method is Shape MCF.
        </Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="enabled_state"
                                   property="EnableBridgeCleanup"
                                   value="1"/>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="BridgeSmoothMethod"
                                   value="1"/>
        </Hints>
      </IntVectorProperty>

      <DoubleVectorProperty command="SetBridgeSmoothTimeStep"
                            name="BridgeSmoothTimeStep"
                            label="Bridge: shape smooth time step"
                            number_of_elements="1"
                            default_values="0.0025"
                            panel_visibility="advanced"
                            animateable="0">
        <Documentation>
          Time step for smooth_shape. Larger values move more per iteration (more shrinkage risk).
        </Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="enabled_state"
                                   property="EnableBridgeCleanup"
                                   value="1"/>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="BridgeSmoothMethod"
                                   value="1"/>
        </Hints>
      </DoubleVectorProperty>

      <IntVectorProperty command="SetBridgeFairContinuity"
                         name="BridgeFairContinuity"
                         label="Bridge: fair continuity"
                         number_of_elements="1"
                         default_values="1"
                         panel_visibility="advanced"
                         animateable="0">
        <EnumerationDomain name="enum">
          <Entry text="C0" value="0"/>
          <Entry text="C1" value="1"/>
          <Entry text="C2" value="2"/>
        </EnumerationDomain>
        <Documentation>
          CGAL fairing_continuity at the cleanup-patch boundary (0=C0, 1=C1, 2=C2). Only used when
          Bridge post-remesh method is Fair. Default C1.
        </Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="enabled_state"
                                   property="EnableBridgeCleanup"
                                   value="1"/>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="visibility"
                                   property="BridgeSmoothMethod"
                                   value="2"/>
        </Hints>
      </IntVectorProperty>

      <IntVectorProperty command="SetExportBridgeMask"
                         name="ExportBridgeMask"
                         label="Bridge: export cleanup mask array"
                         number_of_elements="1"
                         default_values="1"
                         panel_visibility="advanced"
                         animateable="0">
        <BooleanDomain name="bool"/>
        <Documentation>
          Attach cell array SHYXBridgeCleanupMask (1 = cleanup patch) for debugging. Survives
          bridge remesh (post-remesh mask = remeshed cleanup region).
        </Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="enabled_state"
                                   property="EnableBridgeCleanup"
                                   value="1"/>
        </Hints>
      </IntVectorProperty>

      <PropertyGroup label="Bridge cleanup (after union)">
        <Property name="EnableBridgeCleanup"/>
        <Property name="BridgeDilateFromSeam"/>
        <Property name="BridgeDilateLayers"/>
        <Property name="BridgeTargetEdgeLength"/>
        <Property name="BridgeRemeshIterations"/>
        <Property name="BridgeRemeshRelaxationSteps"/>
        <Property name="BridgeSmoothMethod"/>
        <Property name="BridgeSmoothIterations"/>
        <Property name="BridgeSmoothTimeStep"/>
        <Property name="BridgeFairContinuity"/>
        <Property name="ExportBridgeMask"/>
      </PropertyGroup>

      <Hints>
        <ShowInMenu category="SHYX" icon=":/VESPA/VESPA_Hole_Filling.png"/>
      </Hints>
    </SourceProxy>
  </ProxyGroup>
</ServerManagerConfiguration>
