<ServerManagerConfiguration>
  <ProxyGroup name="representations">
    <RepresentationProxy name="PulseGlyphRepresentation"
                         class="vtkPulseGlyphRepresentation"
                         processes="client|dataserver|renderserver"
                         base_proxygroup="representations"
                         base_proxyname="Glyph3DRepresentation">
      <Documentation>
        3D Glyphs with a time-varying pulse scale on the GPU instancing path: each frame the
        PulseGlyphScale point array is filled from the same formula as Animated Streamline
        (integration/time phase and trunc/pow), and vtkGlyph3DMapper uses it as the magnitude
        scale for each instance.
      </Documentation>

      <IntVectorProperty name="Animate"
                         command="SetAnimate"
                         default_values="1"
                         number_of_elements="1">
        <BooleanDomain name="bool" />
      </IntVectorProperty>

      <DoubleVectorProperty name="IntegrationScale"
                            command="SetIntegrationScale"
                            default_values="50"
                            number_of_elements="1">
        <DoubleRangeDomain name="range" min="-10" max="100" />
      </DoubleVectorProperty>

      <DoubleVectorProperty name="TimeScale"
                            command="SetTimeScale"
                            default_values="0.4"
                            number_of_elements="1">
        <DoubleRangeDomain name="range" min="-1" max="3" />
      </DoubleVectorProperty>

      <DoubleVectorProperty name="Trunc"
                            command="SetTrunc"
                            default_values="2"
                            number_of_elements="1">
        <DoubleRangeDomain name="range" min="0.01" max="2" />
      </DoubleVectorProperty>

      <DoubleVectorProperty name="Pow"
                            command="SetPow"
                            default_values="1"
                            number_of_elements="1">
        <DoubleRangeDomain name="range" min="0.1" max="5" />
      </DoubleVectorProperty>

      <DoubleVectorProperty name="PulseOverallScale"
                            command="SetPulseOverallScale"
                            default_values="1"
                            label="Overall scale"
                            number_of_elements="1">
        <DoubleRangeDomain name="range" min="0" max="100" />
        <Documentation>
          Uniform multiplier applied to the pulse value written to PulseGlyphScale (after the
          0–1 envelope from trunc/pow). The standard Glyph Scale Factor still multiplies on top.
        </Documentation>
      </DoubleVectorProperty>

      <StringVectorProperty name="AnimationCoordinateArray"
                            command="SetAnimationCoordinateArray"
                            default_values="IntegrationTime"
                            label="Animation coordinate"
                            number_of_elements="1">
        <Documentation>
          Point data array used as animCoord (scalar or vector magnitude) for the pulse.
          Default: IntegrationTime. If missing, falls back to point radius from the origin.
        </Documentation>
        <RepresentedArrayListDomain name="array_list"
                                    input_domain_name="input_array_any">
          <RequiredProperties>
            <Property function="Input" name="Input" />
          </RequiredProperties>
        </RepresentedArrayListDomain>
      </StringVectorProperty>
    </RepresentationProxy>

    <Extension name="GeometryRepresentation">
      <RepresentationType subproxy="PulseGlyphRepresentation"
                          subtype="Surface"
                          text="Pulse Glyphs" />
      <SubProxy>
        <Proxy name="PulseGlyphRepresentation"
               proxygroup="representations"
               proxyname="PulseGlyphRepresentation" />
        <ShareProperties subproxy="Glyph3DRepresentation">
          <Exception name="Input" />
          <Exception name="Visibility" />
          <Exception name="Representation" />
        </ShareProperties>
        <ExposedProperties>
          <PropertyGroup label="Pulse Glyphs">
            <Property name="PulseOverallScale" exposed_name="PG_OverallScale" />
            <!-- Same subproxy properties as Glyph Parameters; unique exposed_name avoids clash with
                 Glyph3DRepresentation (vtkSMProxy duplicate exposed property warning). -->
            <Property name="Orient" exposed_name="PulseGlyph_Orient" panel_visibility="advanced" />
            <Property name="OrientationMode" exposed_name="PulseGlyph_OrientationMode" panel_visibility="advanced" />
            <Property name="SelectOrientationVectors" exposed_name="PulseGlyph_SelectOrientationVectors" panel_visibility="advanced" />
            <Property name="Scaling" exposed_name="PulseGlyph_Scaling" panel_visibility="advanced" />
            <Property name="ScaleMode" exposed_name="PulseGlyph_ScaleMode" panel_visibility="advanced" />
            <Property name="ScaleFactor" exposed_name="PulseGlyph_ScaleFactor" panel_visibility="advanced" />
            <Property name="SelectScaleArray" exposed_name="PulseGlyph_SelectScaleArray" panel_visibility="advanced" />
            <Property name="GlyphType" exposed_name="PulseGlyph_GlyphType" label="Glyph Type" panel_visibility="default" />
            <Property name="UseGlyphTable" exposed_name="PulseGlyph_UseGlyphTable" panel_visibility="advanced" />
            <Property name="GlyphTableIndexArray" exposed_name="PulseGlyph_GlyphTableIndexArray" panel_visibility="advanced" />
            <Property name="UseCompositeGlyphTable" exposed_name="PulseGlyph_UseCompositeGlyphTable" panel_visibility="advanced" />
            <Property name="UseGlyphCullingAndLOD" exposed_name="PulseGlyph_UseGlyphCullingAndLOD" panel_visibility="advanced" />
            <Property name="LODValues" exposed_name="PulseGlyph_LODValues" panel_visibility="advanced" />
            <Property name="ColorByLODIndex" exposed_name="PulseGlyph_ColorByLODIndex" panel_visibility="advanced" />
            <Property name="Animate" exposed_name="PG_Animate" />
            <Property name="IntegrationScale" exposed_name="PG_IntegrationScale" />
            <Property name="TimeScale" exposed_name="PG_TimeScale" />
            <Property name="Trunc" exposed_name="PG_Trunc" />
            <Property name="Pow" exposed_name="PG_Pow" />
            <Property name="AnimationCoordinateArray" exposed_name="PG_AnimationCoordinateArray" />
            <Hints>
              <PropertyWidgetDecorator type="GenericDecorator"
                                       mode="visibility"
                                       property="Representation"
                                       value="Pulse Glyphs" />
            </Hints>
          </PropertyGroup>
        </ExposedProperties>
      </SubProxy>
    </Extension>

