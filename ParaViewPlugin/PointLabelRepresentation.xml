<ServerManagerConfiguration>
  <ProxyGroup name="representations">
    <RepresentationProxy name="PointLabelRepresentation"
                         class="vtkPointLabelRepresentation"
                         processes="client|dataserver|renderserver"
                         base_proxygroup="representations"
                         base_proxyname="SurfaceRepresentation">
      <Documentation>
        Renders the surface like the standard Surface representation, with optional text labels at
        points. Choose a point-data array; values are converted to strings (vtkLabeledDataMapper
        rules). By default labels are depth-tested (occluded by geometry) and blend with translucent
        objects; disable occlusion to draw them as an always-on-top overlay.
      </Documentation>

      <IntVectorProperty name="ShowPointLabels"
                         command="SetShowPointLabels"
                         default_values="1"
                         number_of_elements="1"
                         label="Show point labels">
        <BooleanDomain name="bool" />
        <Documentation>
          When enabled, draws labels for points using the selected array (subject to the maximum
          label count).
        </Documentation>
      </IntVectorProperty>

      <IntVectorProperty name="OccludeLabels"
                         command="SetOccludeLabels"
                         default_values="1"
                         number_of_elements="1"
                         label="Occlude labels">
        <BooleanDomain name="bool" />
        <Documentation>
          When enabled (default), labels are drawn as 3D billboards in the scene so they can be
          hidden by opaque geometry, blend correctly with transparent objects (depth peeling), and
          use a small depth offset to reduce z-fighting with coincident surfaces (same idea as
          Surface With Edges / selection edge highlights). When disabled, labels are drawn as a 2D
          overlay that always appears on top.
        </Documentation>
      </IntVectorProperty>

      <IntVectorProperty name="ShowEdges"
                         command="SetShowEdges"
                         default_values="0"
                         number_of_elements="1"
                         label="Show edges">
        <BooleanDomain name="bool" />
        <Documentation>
          When enabled, draws mesh edges on the surface like the Surface With Edges representation
          (vtkProperty EdgeVisibility with coincident topology offset). Edge color uses the shared
          Edge Color property. Default is off.
        </Documentation>
      </IntVectorProperty>

      <IntVectorProperty name="VertexOnly"
                         command="SetVertexOnly"
                         default_values="1"
                         number_of_elements="1"
                         label="Vertex only">
        <BooleanDomain name="bool" />
        <Documentation>
          When enabled, labels use only points referenced by vertex cells (vtkPolyData verts or
          VTK_VERTEX in unstructured grids), not every point of lines or surfaces. For Vessel End
          Clipper port 1 this labels each clip origin once (not the arrow tip). Turn off to label
          every point. Default on.
        </Documentation>
      </IntVectorProperty>

      <StringVectorProperty name="PointLabelArray"
                            command="SetPointLabelArray"
                            default_values=""
                            label="Point label array"
                            number_of_elements="1">
        <Documentation>
          Point-data array used for label text. Leave empty (default) to use the active point
          scalars on the displayed mesh (e.g. EndpointIndex on Vessel End Clipper port 1). Choose
          None to disable labeling by array. String arrays show each entry; numeric types use the
          label format (or VTK defaults).
        </Documentation>
        <RepresentedArrayListDomain name="array_list"
                                    input_domain_name="input_array_point"
                                    none_string="None">
          <RequiredProperties>
            <Property function="Input" name="Input" />
          </RequiredProperties>
        </RepresentedArrayListDomain>
      </StringVectorProperty>

      <IntVectorProperty name="MaximumNumberOfLabels"
                         command="SetMaximumNumberOfLabels"
                         default_values="2000"
                         number_of_elements="1"
                         label="Maximum number of labels">
        <IntRangeDomain name="range" min="1" max="1000000" />
        <Documentation>
          Caps how many points are labeled. If the mesh (or Vertex-only subset) has at most this
          many points, every point is labeled. If there are more, an exact random sample of this
          size is used. Note: with Occlude labels on, labels behind opaque geometry are hidden;
          with Vertex only on, only vertex-cell points are candidates.
        </Documentation>
      </IntVectorProperty>

      <StringVectorProperty name="LabelFormat"
                            command="SetLabelFormat"
                            default_values=""
                            label="Label format (printf)"
                            number_of_elements="1">
        <Documentation>
          Optional printf-style format for numeric arrays (e.g. "%.3f"). Leave empty to use VTK
          defaults. String arrays ignore this unless a custom format is needed.
        </Documentation>
      </StringVectorProperty>

      <DoubleVectorProperty name="LabelColor"
                            command="SetLabelColor"
                            default_values="0.9 0.9 0.95"
                            number_of_elements="3"
                            label="Label color">
        <DoubleRangeDomain name="range" min="0 0 0" max="1 1 1" />
        <Documentation>
          RGB color for point label text (overlay and occluded billboard modes).
        </Documentation>
      </DoubleVectorProperty>

      <DoubleVectorProperty name="DepthOffset"
                            command="SetDepthOffset"
                            default_values="-4"
                            number_of_elements="1"
                            label="Depth offset (z-fighting)">
        <DoubleRangeDomain name="range" min="-1024" max="1024" />
        <Documentation>
          Polygon-offset units for occluded (3D) labels. Negative values pull labels toward the
          camera to reduce z-fighting with coincident surfaces (same idea as Surface With Edges
          line offset, default -4). More negative floats labels farther in front; closer to 0
          allows more fighting. Only applies when Occlude labels is enabled.
        </Documentation>
        <Hints>
          <PropertyWidgetDecorator type="GenericDecorator"
                                   mode="enabled_state"
                                   property="OccludeLabels"
                                   value="0"
                                   inverse="1"/>
        </Hints>
      </DoubleVectorProperty>
    </RepresentationProxy>

    <Extension name="GeometryRepresentation">
      <RepresentationType subproxy="PointLabelRepresentation"
                          text="Point Label" />
      <SubProxy>
        <Proxy name="PointLabelRepresentation"
               proxygroup="representations"
               proxyname="PointLabelRepresentation" />
        <ShareProperties subproxy="SurfaceRepresentation">
          <Exception name="Input" />
          <Exception name="Visibility" />
          <Exception name="Representation" />
        </ShareProperties>
        <ExposedProperties>
          <PropertyGroup label="Point Labels">
            <Property name="ShowPointLabels" exposed_name="PL_ShowPointLabels" />
            <Property name="OccludeLabels" exposed_name="PL_OccludeLabels" />
            <Property name="ShowEdges" exposed_name="PL_ShowEdges" />
            <Property name="VertexOnly" exposed_name="PL_VertexOnly" />
            <Property name="PointLabelArray" exposed_name="PL_PointLabelArray" />
            <Property name="MaximumNumberOfLabels" exposed_name="PL_MaximumNumberOfLabels" />
            <Property name="LabelFormat" exposed_name="PL_LabelFormat" />
            <Property name="LabelColor" exposed_name="PL_LabelColor" />
            <Property name="DepthOffset" exposed_name="PL_DepthOffset" />
            <Hints>
              <PropertyWidgetDecorator type="GenericDecorator"
                                       mode="visibility"
                                       property="Representation"
                                       value="Point Label" />
            </Hints>
          </PropertyGroup>
        </ExposedProperties>
      </SubProxy>
    </Extension>

