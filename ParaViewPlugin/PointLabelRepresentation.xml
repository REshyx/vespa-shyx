                                       value="Point Label" />
            </Hints>
          </PropertyGroup>
        </ExposedProperties>
      </SubProxy>
    </Extension>

    <Extension name="StructuredGridRepresentation">
      <RepresentationType subproxy="PointLabelRepresentation"
                          text="Point Label" />
      <SubProxy>
        <Proxy name="PointLabelRepresentation"
