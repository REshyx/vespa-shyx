<mxfile host="app.diagrams.net" modified="2026-05-03T00:00:00.000Z" agent="Cursor" version="22.1.0">
  <diagram id="remesher-flow" name="AdaptiveIsotropicRemesher">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="2200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="vtkSHYXAdaptiveIsotropicRemesher — 标志位 / 参数 → 特征边 / 特征点 / Remesh / Smooth" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="920" height="40" as="geometry" />
        </mxCell>

        <!-- Column: legend -->
        <mxCell id="legend" value="图例&#xa;────&#xa;实线：主流程；虚线：多路汇合&#xa;菱形：分支&#xa;&#xa;输入 port0 表面；port1 vtkSelection（可选）；&#xa;输出 port0 remesh 结果；port1 特征线/点；port2 mask 子网格" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;spacingLeft=8;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="1000" y="60" width="260" height="140" as="geometry" />
        </mxCell>

        <!-- Start -->
        <mxCell id="start" value="RequestData&#xa;输入 port0 vtkPolyData" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="200" height="56" as="geometry" />
        </mxCell>

        <mxCell id="validate" value="校验&#xa;AdaptiveTolerance &gt; 0&#xa;NumberOfIterations ≥ 1&#xa;NumberOfRelaxationSteps ≥ 0&#xa;ShapeSmoothing：迭代≥0；若&gt;0 则 TimeStep&gt;0&#xa;0 &lt; MinEdgeLength &lt; MaxEdgeLength&#xa;包围盒非退化" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=6" vertex="1" parent="1">
          <mxGeometry x="40" y="160" width="280" height="120" as="geometry" />
        </mxCell>
        <mxCell id="e0" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="start" target="validate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Feature mask branch -->
        <mxCell id="fmdec" value="FeatureMaskEnabled ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6" vertex="1" parent="1">
          <mxGeometry x="100" y="300" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="validate" target="fmdec">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="fmmask" value="ComputeFeatureFaceMask&#xa;FeatureMaskArrayName&#xa;FeatureMaskThreshold（模长 &gt; 阈值）&#xa;FeatureMaskAllScalars（仅点数组：全角点 / 任一角点）&#xa;同名点+胞：优先胞数组" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=6" vertex="1" parent="1">
          <mxGeometry x="360" y="280" width="300" height="100" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="是" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="fmdec" target="fmmask">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="fmok" value="mask 求值成功 ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6" vertex="1" parent="1">
          <mxGeometry x="420" y="400" width="140" height="72" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="fmmask" target="fmok">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="port2" value="output port2&#xa;ExtractMaskedFacesPolyData&#xa;（mask 子网格）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="360" y="500" width="260" height="64" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="是" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="fmok" target="port2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="fmfail" value="inputFeatureMaskOk=false&#xa;port2 空；后续按「无 mask」&#xa;警告" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=6" vertex="1" parent="1">
          <mxGeometry x="600" y="404" width="220" height="72" as="geometry" />
        </mxCell>
        <mxCell id="e5" value="否" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="fmok" target="fmfail">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="nomask" value="port2 清空&#xa;inputFeatureMaskOk=false" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666" vertex="1" parent="1">
          <mxGeometry x="80" y="420" width="200" height="56" as="geometry" />
        </mxCell>
        <mxCell id="e6" value="否" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="fmdec" target="nomask">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="180" y="360" />
              <mxPoint x="180" y="448" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Merge before selection -->
        <mxCell id="mergeA" value="汇合" style="ellipse;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#999999" vertex="1" parent="1">
          <mxGeometry x="180" y="600" width="80" height="40" as="geometry" />
        </mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1" edge="1" parent="1" source="port2" target="mergeA">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="490" y="600" />
              <mxPoint x="220" y="600" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1" edge="1" parent="1" source="nomask" target="mergeA">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8b" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1" edge="1" parent="1" source="fmfail" target="mergeA">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="710" y="580" />
              <mxPoint x="220" y="580" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Selection -->
        <mxCell id="sel" value="选区 selected（面 id 集合）&#xa;port1 vtkSelection → vtkExtractSelection → CollectCellsFromExtracted（vtkOriginalCellIds / 点选回推）&#xa;无有效选区则整面 remesh" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=6" vertex="1" parent="1">
          <mxGeometry x="40" y="660" width="400" height="88" as="geometry" />
        </mxCell>
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="mergeA" target="sel">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="tocgal" value="toCGAL(input) → cgalMesh&#xa;remeshFaces = selected 对应 CGAL 面（有效则 patchRemesh）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=6" vertex="1" parent="1">
          <mxGeometry x="40" y="770" width="400" height="64" as="geometry" />
        </mxCell>
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="sel" target="tocgal">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Pre-remesh features -->
        <mxCell id="prefeat" value="【Remesh 前】构造 edge_is_constrained（featureEdges）&#xa;1) detect_sharp_edges(surface, ProtectAngle)&#xa;2) ApplySharpFeatureSideFilter(SharpFeatureSideFilter: 0 不变 / 1 去掉凹 / 2 去掉凸；边界不动）&#xa;3) 若 maskOk：ApplyFeatureRegionMaskToSharpEdges（两面都过 mask 才保留内棱）&#xa;4) 若 maskOk 且 port2 非空：在 mask patch 上再 detect + SideFilter → LiftPatchSharpFeaturesToFullMesh（量化匹配棱到全网格）&#xa;5) 若 selected 非空：AddSelectionBoundaryUsingVtkTopology（选区边界棱）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=6;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="40" y="860" width="520" height="130" as="geometry" />
        </mxCell>
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="tocgal" target="prefeat">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Remesh -->
        <mxCell id="remesh" value="isotropic_remeshing&#xa; sizing = Adaptive_sizing_field(AdaptiveTolerance, [MinEdgeLength, MaxEdgeLength], faces)&#xa; faces = remeshFaces（patch）或全部面&#xa; 命名参数：&#xa; • NumberOfIterations&#xa; • NumberOfRelaxationSteps（每轮切向松弛）&#xa; • RemeshProtectConstraints / RemeshCollapseConstraints / RemeshRelaxConstraints&#xa; • RemeshDoSplit / RemeshDoCollapse / RemeshDoFlip&#xa; • edge_is_constrained_map = featureEdges" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=6;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="40" y="1010" width="520" height="150" as="geometry" />
        </mxCell>
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="prefeat" target="remesh">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Smooth branch -->
        <mxCell id="smoothdec" value="ShapeSmoothingIterations &gt; 0 ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="1">
          <mxGeometry x="200" y="1190" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="e13" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="remesh" target="smoothdec">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="smoothblk" value="【smooth_shape】&#xa;锚点 smoothAnchorPoints：&#xa; • CollectSelectionBoundaryWorldPoints（选区边界顶点）&#xa; • 若 maskOk 且 port2 非空：CollectPatchSharpFeatureWorldPoints（ProtectAngle + SharpFeatureSideFilter 在 patch 上）&#xa;容差 tol ≈ 1e-4 × 包围盒对角尺度（平方距离）&#xa;&#xa;再次 detect_sharp_edges + SideFilter&#xa;若需 probe（maskOk 或 有选区）：&#xa; toVTK 临时网格 + interpolateAttributes&#xa; • maskOk：在 tmpSurf 上重算 mask → ApplyFeatureRegionMaskToSharpEdges&#xa; • 有选区：内部 VESPA_InternalSelectionTag → AddPatchBoundaryFeatureEdges&#xa;&#xa;vertex_is_constrained：所有 feature 边端点 + MarkVerticesNearAnchorPoints&#xa;smooth_shape(ShapeSmoothingTimeStep, iterations=ShapeSmoothingIterations)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=6;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="480" y="1170" width="420" height="220" as="geometry" />
        </mxCell>
        <mxCell id="e14" value="是" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="smoothdec" target="smoothblk">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="420" y="1230" />
              <mxPoint x="420" y="1280" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="nosmooth" value="跳过 smooth_shape" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666" vertex="1" parent="1">
          <mxGeometry x="40" y="1200" width="140" height="48" as="geometry" />
        </mxCell>
        <mxCell id="e15" value="否" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="smoothdec" target="nosmooth">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="mergeB" value="汇合" style="ellipse;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#999999" vertex="1" parent="1">
          <mxGeometry x="180" y="1420" width="80" height="40" as="geometry" />
        </mxCell>
        <mxCell id="e16" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1" edge="1" parent="1" source="smoothblk" target="mergeB">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="690" y="1440" />
              <mxPoint x="220" y="1440" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e17" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1" edge="1" parent="1" source="nosmooth" target="mergeB">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="110" y="1320" />
              <mxPoint x="220" y="1320" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="out0" value="toVTK → output port0&#xa;interpolateAttributes(input → output)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="80" y="1480" width="280" height="56" as="geometry" />
        </mxCell>
        <mxCell id="e18" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="mergeB" target="out0">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Port 1 -->
        <mxCell id="p1dec" value="FeatureMaskEnabled &amp;&amp; inputFeatureMaskOk ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6" vertex="1" parent="1">
          <mxGeometry x="100" y="1550" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="e19" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="out0" target="p1dec">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="p1hascells" value="output port2&#xa;胞数 &gt; 0 ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6" vertex="1" parent="1">
          <mxGeometry x="400" y="1540" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="e20y" value="是" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="p1dec" target="p1hascells">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="p1empty" value="port2 无胞&#xa;→ outputFeatures.Initialize()&#xa;（port1 空，不做全网格特征）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=6" vertex="1" parent="1">
          <mxGeometry x="600" y="1536" width="240" height="72" as="geometry" />
        </mxCell>
        <mxCell id="e20n" value="否" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="p1hascells" target="p1empty">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="p1patch" value="在 port2 mask patch 上 toCGAL&#xa;detect_sharp_edges + SharpFeatureSideFilter&#xa;→ FillFeaturePolyDataSharpLinesOnly（LINE）&#xa;若 ShapeSmoothingIterations&gt;0：port3 非空则 AppendSharpFeatureVerts（VERTEX）&#xa;否则无 VERTEX；失败/异常：回退「全网格」分支" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=6;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="360" y="1640" width="360" height="96" as="geometry" />
        </mxCell>
        <mxCell id="e21" value="是" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="p1hascells" target="p1patch">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="p1full" value="全输出网格 port1（!port1FromExtractedPatch）&#xa;• mask 未启用 或 mask 求值失败&#xa;• 或 patch CGAL 失败（从上一框回退）&#xa;detect_sharp_edges + SideFilter → SharpLinesOnly&#xa;若 FeatureMaskEnabled：在 output 上再算 mask 过滤棱&#xa;平滑&gt;0 时追加 VERTEX（无 mask 从全 remesh；有 mask 且 port3 空则无 VERTEX）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=6;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="40" y="1760" width="500" height="96" as="geometry" />
        </mxCell>
        <mxCell id="e22n" value="否" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="p1dec" target="p1full">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="220" y="1590" />
              <mxPoint x="290" y="1590" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="end" value="return 1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="200" y="1880" width="120" height="48" as="geometry" />
        </mxCell>
        <mxCell id="e24" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="p1patch" target="end">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="560" y="1870" />
              <mxPoint x="260" y="1870" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e25" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="p1full" target="end">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e26" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="p1empty" target="end">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="720" y="1920" />
              <mxPoint x="260" y="1920" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Side annotations: parameter groups -->
        <mxCell id="note1" value="特征边 / Remesh 约束&#xa;──────────────&#xa;ProtectAngle：多大二面角算「锐」&#xa;SharpFeatureSideFilter：内棱凹凸筛选&#xa;Feature mask：限制哪些面上的锐棱参与约束（可与 patch 提升合并）&#xa;选区：边界棱强制为特征&#xa;Remesh*：控制约束边是否可分裂/塌缩/松弛及拓扑操作" style="shape=note;whiteSpace=wrap;html=1;size=16;fillColor=#fffacd;strokeColor=#d6b656;align=left;spacingLeft=8;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="1000" y="220" width="280" height="160" as="geometry" />
        </mxCell>

        <mxCell id="note2" value="Smooth&#xa;────&#xa;ShapeSmoothingIterations / TimeStep&#xa;平滑后仍保持：重检的锐边顶点 + 选区边界与 mask 特征锚点附近顶点（几何锁定）" style="shape=note;whiteSpace=wrap;html=1;size=16;fillColor=#fffacd;strokeColor=#d6b656;align=left;spacingLeft=8;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="1000" y="1120" width="280" height="100" as="geometry" />
        </mxCell>

        <mxCell id="note3" value="输出 port1 特征&#xa;──────────&#xa;mask 成功：port2 无胞 → port1 空；port2 有胞 → 仅在 patch 上提特征（与 port2 同几何）&#xa;否则（无 mask / mask 失败 / patch CGAL 失败）：在全输出上提特征；启用 mask 时仍可再过滤" style="shape=note;whiteSpace=wrap;html=1;size=16;fillColor=#fffacd;strokeColor=#d6b656;align=left;spacingLeft=8;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="1000" y="1560" width="280" height="100" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
